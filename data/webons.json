  "features_and_traits": {
    "feats": [
      {
        "name": "Iniciado en la magia",
        "source": "Dotes",
        "description": "Aprendes 2 trucos y 1 conjuro de nivel 1 de una lista (clérigo, druida o mago). Puedes lanzar el conjuro gratis 1 vez por descanso largo y cambiar los conjuros al subir de nivel."
      },
      {
        "name": "Afortunado",
        "source": "Dotes",
        "description": "Tienes una cantidad de puntos de suerte igual a tu bonificador por competencia y puedes gastarlos para darte Ventaja (1 punto) o dar Desventaja a una criatura que ataque contra ti (1 punto). Recuperas los puntos gastados tras un descanso largo."
      }
    ],
    "species": [
      {
        "name": "Diestro",
        "source": "Humano",
        "description": "Ganas competencia en una habilidad de tu elección."
      },
      {
        "name": "Ingenioso",
        "source": "Humano",
        "description": "Obtienes inspiración heroica tras finalizar un descanso largo."
      },
      {
        "name": "Versátil",
        "source": "Humano",
        "description": "Obtienes una dote de origen de tu elección (consulta el capítulo 5). Se recomienda Habilidoso."
      }
    ],
    "class_features": [
      {
        "name": "Artes marciales",
        "source": "Monje",
        "description": "Cuando usas arma de monje y no llevas armadura ni escudo: Puedes usar Des en lugar de Fue para ataque y daño. Puedes usar el dado de daño desarmado en lugar del daño del arma. Tras atacar desarmado o con arma de monje, puedes usar una acción adicional para realizar un ataque desarmado."
      },
      {
        "name": "Concentración de monje",
        "source": "Monje",
        "description": "Tienes puntos de Concetración igual a tu nivel de monje. Ganas Defensa paciente (destrabarse como Acción Adicional, gasta 1 PC y también esquivas), Paso del viento (correr como Acción Adicional,  gasta 1 PC y también te destrabas) y Ráfaga de golpes (1, dos atacas sin arma como Acción adicional)"
      },
      {
        "name": "Defensa paciente",
        "source": "Monje",
        "description": "Puedes llevar a cabo la acción de destrabarse como acción adicional. De manera alternativa, puedes gastar 1 punto de concentración para llevar a cabo tanto la acción de destrabarse como la de esquivar como acción adicional."
      },
      {
        "name": "Defensa sin armadura",
        "source": "Monje",
        "description": "Mientras no lleves armadura ni portes un escudo, tu clase de armadura base será igual a 10 más tus modificadores por Destreza y Sabiduría."
      },
      {
        "name": "Metabolismo asombroso",
        "source": "Monje",
        "description": "Una vez por descanso largo, cuando tires iniciativa, recupera todos tus puntos de concentración gastados y lanza tu dado de Artes marciales. Recuperas PG igual al resultado más tu nivel de monje."
      },
      {
        "name": "Movimiento sin armadura",
        "source": "Monje",
        "description": "Tu velocidad aumenta en3 metrossi no llevas armadura ni portas un escudo. Esta bonificación aumenta cuando alcanzas ciertos niveles de monje."
      },
      {
        "name": "Paso del viento",
        "source": "Monje",
        "description": "Puedes llevar a cabo la acción de correr como acción adicional. De manera alternativa, puedes gastar 1 punto de concentración para llevar a cabo tanto la acción de destrabarse como la de correr como acción adicional, y tu distancia de salto se duplicará durante el turno."
      },
      {
        "name": "Ráfaga de golpes",
        "source": "Monje",
        "description": "Puedes gastar 1 punto de concentración para hacer dos ataques sin armas como acción adicional."
      }
    ]
  },
